DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qa_report?schema=public"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
OPENROUTER_API_KEY=""
OPENROUTER_PAID_MODEL="openai/gpt-4.1-mini"
OPENROUTER_FREE_MODEL="openai/gpt-oss-120b:free"
