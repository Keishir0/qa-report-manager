generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(QA)
  active       Boolean       @default(true)
  sndeskUserId String?       @map("sndesk_user_id")
  sndeskStatusId String?     @map("sndesk_status_id")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     AuthSession[]
  aiGenerations AiGenerationLog[]
  testedReports TestReport[]

  @@map("users")
}

model AiGenerationLog {
  id        String   @id @default(cuid())
  userId    String
  mode      String
  provider  String
  model     String
  status    String
  latencyMs Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, status, createdAt])
  @@map("ai_generation_logs")
}

model AuthSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model LoginThrottle {
  key             String    @id
  attempts        Int       @default(0)
  windowStartedAt DateTime  @default(now())
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@map("login_throttles")
}

model TestReport {
  id              String           @id @default(cuid())
  code            String           @unique
  testDate        DateTime
  systemName      String
  branch          String
  screenPath      String
  functionality   String
  bugDescription  String
  testType        String
  generalStatus   String
  notes           String?
  testerId        String?          @map("tester_id")
  testerName      String?          @map("tester_name")
  sndeskTechnicianName String?     @map("sndesk_technician_name")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?        @map("deleted_at")
  sndeskChamadoId String?          @unique @map("sndesk_chamado_id")
  pendingTicket   QaPendingTicket?
  tester          User?            @relation(fields: [testerId], references: [id], onDelete: SetNull)
  steps           TestStep[]

  @@index([testerId])
  @@index([testerName])
  @@index([sndeskTechnicianName])
  @@index([deletedAt])
  @@map("test_reports")
}

model TestStep {
  id             String     @id @default(cuid())
  reportId       String
  stepNumber     Int
  action         String
  expectedResult String
  actualResult   String
  status         String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  report         TestReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("test_steps")
}

model ExternalWebhookEvent {
  id         String   @id @default(cuid())
  event      String
  idChamado  String
  idRef      String
  customJson Json?    @map("json")
  rawPayload Json
  sourceIp   String?
  userAgent  String?
  status     String   @default("recebido")
  receivedAt DateTime @default(now())

  @@index([event])
  @@index([idChamado])
  @@index([receivedAt])
  @@map("external_webhook_events")
}

model WebhookSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("webhook_settings")
}

model QaPendingTicket {
  id              String      @id @default(cuid())
  idChamado       String      @unique
  statusId        Int?
  statusDescricao String?
  statusCor       String?
  chamadoSnapshot Json?
  reportId        String?     @unique
  state           String      @default("pendente")
  lastError       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  report          TestReport? @relation(fields: [reportId], references: [id])

  @@index([state])
  @@index([statusId])
  @@map("qa_pending_tickets")
}

enum UserRole {
  ADMIN
  QA
  VIEWER
}
